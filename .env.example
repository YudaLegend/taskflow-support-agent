# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
#
# Anything in .env is loaded by python-dotenv at process startup.
# In Docker, the same file is read via `env_file:` in docker-compose.yml,
# and per-service `environment:` blocks override values for in-network DNS.

# --- Required -------------------------------------------------------------
# Groq API key. Free tier — sign up at https://console.groq.com/keys
GROQ_API_KEY=

# --- MongoDB --------------------------------------------------------------
# Default: local MongoDB Service on the host machine.
# For MongoDB Atlas (free M0 tier), copy the SRV connection string from
# Atlas → Connect → Drivers → "Connection string". Looks like:
#     mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB=taskflow

# --- ChromaDB persistence -------------------------------------------------
# Where the embedded vector store keeps its files. Defaults to data/chroma_db
# relative to the project root.
# CHROMA_PATH=data/chroma_db

# --- Langfuse observability — optional but recommended -------------------
# Sign up free at https://cloud.langfuse.com (EU) or https://us.cloud.langfuse.com (US).
# Project Settings → API Keys → "Create new API keys" — copy the secret immediately,
# it's shown only once.
# Without these set, the agent runs fine but no traces are emitted (graceful
# degradation — see agent/graph.py::get_langfuse_handler).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
